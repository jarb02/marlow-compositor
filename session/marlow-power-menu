#!/bin/bash
# marlow-power-menu — Power menu via wofi
# Accessible from: waybar power button, Super+P keybind

OPTIONS='🔒 Lock\n🚪 Logout\n😴 Suspend\n🔄 Reboot\n⏻ Shutdown'

choice=$(printf "$OPTIONS" | wofi --show dmenu --cache-file /dev/null --prompt "Power")

# Strip emoji prefix to match
action=$(echo "$choice" | sed 's/^[^ ]* //')

case "$action" in
    Lock)
        swaylock -f -c 1a1a2e ;;
    Logout)
        pkill -SIGTERM -f marlow-compositor ;;
    Suspend)
        swaylock -f -c 1a1a2e &
        sleep 1
        systemctl suspend ;;
    Reboot)
        systemctl reboot ;;
    Shutdown)
        systemctl poweroff ;;
esac
